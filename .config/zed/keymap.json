// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    // Main vim bindings
    "context": "VimControl",
    "bindings": {
      "space": null, // Disables next character behaviour for space key
      "ctrl-w": null, // Disables tab closing behaviour when not inputting anything after ctrl-w

      "] t": "vim::GoToTab",
      "[ t": "vim::GoToPreviousTab",

      "space p o": "workspace::Open",
      "space p r": "projects::OpenRecent",

      "space e": "project_panel::ToggleFocus",
      "space f f": "file_finder::Toggle",
      "space f g": "workspace::NewSearch",

      "space d": "diagnostics::Deploy",

      "space c a": "editor::ToggleCodeActions",
      "space c i": "assistant::InlineAssist",
      "space c c": "agent::ToggleFocus",

      "space g g": "git_panel::ToggleFocus",
      "space g d": "git::Diff",
      "space g t": "git::ToggleStaged",
      "space g r": "git::Restore",
      "space g s": "git::StageAndNext",
      "space g u": "git::UnstageAndNext",
      "space g b": "git::Blame",
      "space g c": "git::Commit",
      "space g p": "git::PullRebase",
      "space g P": "git::Push",
      "space g B": "git::Branch",
      "space g x": "git_graph::Open",
    },
  },
  {
    // Seemless navigation between editor and dock panels
    "context": "VimControl || Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    // Close any panel that is not the editor
    "context": "Dock || MessageEditor",
    "bindings": {
      "ctrl-w": "workspace::CloseActiveDock",
    },
  },
  {
    // Navigating files in project panel
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "h": "project_panel::CollapseSelectedEntry",
      "l": "project_panel::ExpandSelectedEntry",
      "o": "project_panel::Open",
    },
  },
]
